// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum Role {
  PROFESSOR
  MANAGER
  ASSISTANT
}

//////////////////////
// CORE USER SYSTEM
//////////////////////

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  isValid      Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Relations
  student Student?
  staff   StaffMember?

  otpverifications OTPVerification?
}

model OTPVerification {
  id        String   @id @default(cuid())
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
}

model StaffMember {
  userId Int @id
  // roleId Int

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              Role
  markedAttendances Attendance[] @relation("MarkedBy")
}

model Student {
  userId      Int    @id
  studentCode String @unique
  classId     Int

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  class       Class        @relation(fields: [classId], references: [id])
  attendances Attendance[]
}

//////////////////////
// ACADEMIC STRUCTURE
//////////////////////

model Department {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  classes Class[]
}

model Class {
  id           Int     @id @default(autoincrement())
  name         String
  classCode    String  @unique
  departmentId Int
  year         Int
  description  String?

  // Relations
  department Department    @relation(fields: [departmentId], references: [id])
  students   Student[]
  sessions   Session[]
  modules    ClassModule[]
}

model Module {
  id          Int     @id @default(autoincrement())
  name        String
  code        String  @unique
  description String?

  // Relations
  classes  ClassModule[]
  sessions Session[]
}

model ClassModule {
  classId  Int
  moduleId Int

  // Relations
  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([classId, moduleId])
}

//////////////////////
// SCHEDULING
//////////////////////

model Room {
  id       Int       @id @default(autoincrement())
  name     String
  sessions Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  classId   Int
  moduleId  Int
  dayOfWeek Int
  startTime DateTime @db.Time
  endTime   DateTime @db.Time

  // Relations
  room       Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  class      Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  module     Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attendance Attendance[]
  roomId     Int
}

//////////////////////
// ATTENDANCE
//////////////////////

model Attendance {
  id        Int              @id @default(autoincrement())
  studentId Int
  sessionId Int
  date      DateTime
  status    AttendanceStatus
  markedBy  Int?
  createdAt DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  marker StaffMember? @relation("MarkedBy", fields: [markedBy], references: [userId])

  @@unique([studentId, sessionId, date])
}
